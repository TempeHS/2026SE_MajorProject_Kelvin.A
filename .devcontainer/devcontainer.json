{
  "name": "2026SE Major Project",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y xvfb x11vnc novnc websockify git-lfs && git lfs install && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "batisteo.vscode-django",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "donjayamanne.python-environment-manager",
        "donjayamanne.python-extension-pack",
        "esbenp.prettier-vscode",
        "github.vscode-pull-request-github",
        "kevinrose.vsc-python-indent",
        "mathematic.vscode-pdf",
        "mechatroner.rainbow-csv",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.pylint",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "njpwerner.autodocstring",
        "oderwat.indent-rainbow",
        "saeris.markdown-github-alerts",
        "tushortz.pygame-snippets",
        "vscode-icons-team.vscode-icons",
        "wholroyd.jinja",
        "yy0931.vscode-sqlite3-editor"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  }
}
